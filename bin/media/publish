#!/usr/bin/env bash
set -euo pipefail

# Usage:
#   ./bin/media/publish <post-path>
#   ./bin/media/publish --remove-local <post-path>

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "$script_dir/../.." && pwd)"

exec node "$repo_root/scripts/publish-post-media.mjs" "$@"
