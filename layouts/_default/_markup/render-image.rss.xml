{{- $dest := .Destination -}}
{{- $src := $dest -}}
{{- $parsed := urls.Parse $dest -}}
{{- if and (not $parsed.Scheme) (not (strings.HasPrefix $dest "//")) -}}
  {{- if strings.HasPrefix $dest "/" -}}
    {{- $src = $dest | absURL -}}
  {{- else -}}
    {{- with .Page.Resources.GetMatch $dest -}}
      {{- $src = .Permalink -}}
    {{- else -}}
      {{- $src = printf "%s%s" .Page.Permalink $dest -}}
    {{- end -}}
  {{- end -}}
{{- end -}}
<img src="{{ $src }}" alt="{{ .Text }}"{{ with .Title }} title="{{ . }}"{{ end }}>
