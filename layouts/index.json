{{- $pages := partial "feed-posts.html" . -}}
{{- $limit := .Site.Config.Services.RSS.Limit -}}
{{- if ge $limit 1 -}}
  {{- $pages = first $limit $pages -}}
{{- end -}}

{{- $homeURL := .Site.Home.Permalink -}}
{{- $feedURL := .Permalink -}}
{{- with .OutputFormats.Get "JSON" -}}
  {{- $feedURL = .Permalink -}}
{{- end -}}

{{- $authorName := "" -}}
{{- with .Site.Params.author -}}
  {{- if reflect.IsMap . -}}
    {{- with .name -}}
      {{- $authorName = . -}}
    {{- end -}}
  {{- else -}}
    {{- $authorName = . -}}
  {{- end -}}
{{- end -}}
{{- $authorURL := .Site.Home.Permalink -}}
{{- $authorAvatar := "/icon.png" | absURL -}}

{{- $author := dict -}}
{{- with $authorName -}}
  {{- $author = merge $author (dict "name" .) -}}
{{- end -}}
{{- with $authorURL -}}
  {{- $author = merge $author (dict "url" .) -}}
{{- end -}}
{{- with $authorAvatar -}}
  {{- $author = merge $author (dict "avatar" .) -}}
{{- end -}}
{{- $authors := slice -}}
{{- if gt (len $author) 0 -}}
  {{- $authors = $authors | append $author -}}
{{- end -}}

{{- $description := .Site.Params.description | default (printf "Articles and notes by %s" .Site.Title) -}}
{{- $userComment := "JSON Feed for articles and notes." -}}
{{- $icon := "/web-app-manifest-512x512.png" | absURL -}}
{{- $favicon := "/favicon-96x96.png" | absURL -}}
{{- $language := .Site.Language.LanguageCode | default .Site.Language.Lang -}}
{{- $expired := false -}}
{{- if isset .Site.Params "jsonfeed_expired" -}}
  {{- $expired = .Site.Params.jsonfeed_expired -}}
{{- end -}}

{{- $items := slice -}}
{{- range $pages -}}
  {{- $summary := .Summary | plainify | htmlUnescape | replaceRE `\s+` ` ` | strings.TrimSpace -}}
  {{- $contentText := .Plain | plainify | htmlUnescape | replaceRE `\s+` ` ` | strings.TrimSpace -}}
  {{- $externalURL := .Params.bookmarkOf -}}
  {{- if not $externalURL -}}
    {{- $externalURL = .Params.external_url -}}
  {{- end -}}

  {{- $image := .Params.image -}}
  {{- if not $image -}}
    {{- $images := .Params.images -}}
    {{- if and $images (reflect.IsSlice $images) (gt (len $images) 0) -}}
      {{- $image = index $images 0 -}}
    {{- end -}}
  {{- end -}}

  {{- $bannerImage := .Params.banner_image -}}
  {{- if not $bannerImage -}}
    {{- $bannerImage = .Params.bannerImage -}}
  {{- end -}}

  {{- $item := dict
    "id" .Permalink
    "url" .Permalink
    "content_html" .Content
    "content_text" $contentText
    "date_published" (.Date.Format "2006-01-02T15:04:05-07:00")
    "language" (.Language.LanguageCode | default .Lang | default $language)
  -}}
  {{- if not .Lastmod.IsZero -}}
    {{- $item = merge $item (dict "date_modified" (.Lastmod.Format "2006-01-02T15:04:05-07:00")) -}}
  {{- end -}}
  {{- with .Title -}}
    {{- $item = merge $item (dict "title" .) -}}
  {{- end -}}
  {{- with $externalURL -}}
    {{- $item = merge $item (dict "external_url" .) -}}
  {{- end -}}
  {{- with $summary -}}
    {{- $item = merge $item (dict "summary" .) -}}
  {{- end -}}
  {{- with $image -}}
    {{- $item = merge $item (dict "image" ((printf "%v" .) | absURL)) -}}
  {{- end -}}
  {{- with $bannerImage -}}
    {{- $item = merge $item (dict "banner_image" ((printf "%v" .) | absURL)) -}}
  {{- end -}}
  {{- with .Params.tags -}}
    {{- if gt (len .) 0 -}}
      {{- $item = merge $item (dict "tags" .) -}}
    {{- end -}}
  {{- end -}}
  {{- $items = $items | append $item -}}
{{- end -}}

{{- $feed := dict
  "version" "https://jsonfeed.org/version/1.1"
  "title" .Site.Title
  "home_page_url" $homeURL
  "feed_url" $feedURL
  "description" $description
  "user_comment" $userComment
  "icon" $icon
  "favicon" $favicon
  "language" $language
  "expired" $expired
  "items" $items
-}}

{{- if gt (len $authors) 0 -}}
  {{- $feed = merge $feed (dict "authors" $authors) -}}
  {{- $feed = merge $feed (dict "author" (index $authors 0)) -}}
{{- end -}}

{{- with .Site.Params.jsonfeed_hubs -}}
  {{- $hubs := slice -}}
  {{- range . -}}
    {{- if and .type .url -}}
      {{- $hubs = $hubs | append (dict "type" .type "url" .url) -}}
    {{- end -}}
  {{- end -}}
  {{- if gt (len $hubs) 0 -}}
    {{- $feed = merge $feed (dict "hubs" $hubs) -}}
  {{- end -}}
{{- end -}}

{{- $feed | jsonify (dict "indent" "  ") -}}
